PORT=5000
API_PUBLIC_URL=http://localhost:5000
AUDIUS_APP_NAME=Audiq
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Official YouTube Data API key. Enables YouTube search results and visible iframe playback.
YOUTUBE_API_KEY=

# Optional authorized/official JioSaavn-compatible API endpoint.
# Must return legal playable media URLs; unofficial scraping endpoints should not be used.
JIOSAAVN_API_BASE_URL=
JIOSAAVN_SEARCH_PATH=/search
JIOSAAVN_QUERY_PARAM=q
JIOSAAVN_API_KEY=
